/****************************************************************************
 * boards/spike-prime-hub/src/etc/init.d/rcS
 *
 * NSH start-up script.  Auto-launches the btsensor and drivebase daemons at
 * console boot.
 *
 * Executed once by nsh_initscript() (idempotent via g_nsh_script_initialized)
 * after BOARDCTL_INIT and BOARDCTL_FINALINIT have completed, so all kernel
 * drivers are ready.  btnsh sessions reach NSH via nsh_session() directly
 * and never re-enter this script.
 *
 * `drivebase start` uses the default 56 mm wheel / 112 mm axle / 2 ms tick.
 * If no motors are attached it fails fast with an error line — non-fatal,
 * the daemon simply does not come up (Issue #120).
 ****************************************************************************/

#include <nuttx/config.h>

#ifdef CONFIG_APP_BTSENSOR
btsensor start
#endif

#ifdef CONFIG_APP_DRIVEBASE
drivebase start
#endif
