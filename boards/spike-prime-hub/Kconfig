#
# Board-specific Kconfig for SPIKE Prime Hub
#

config SPIKE_SOUND_PCM_BUFSAMPLES
	int "PCM DMA buffer size (uint16_t samples)"
	default 1024
	range 256 8192
	---help---
		Size of the kernel-side DMA source buffer used by /dev/pcm0.
		Default 1024 samples = 2 KB.  Playback is cyclic (one period
		loops until stop), so this buffer holds one waveform period
		rather than an entire track.

config LEGO_PORT
	bool "LEGO Powered Up I/O port (/dev/legoport[0-5])"
	default n
	depends on SCHED_HPWORK
	depends on ARCH_CHIP_STM32F413VG || ARCH_CHIP_STM32F413ZH
	depends on !STM32_USART6
	select STM32_TIM1
	select STM32_TIM3
	select STM32_TIM4
	---help---
		Enable the LEGO Powered Up I/O port driver for the 6 external
		ports (A-F) on the SPIKE Prime Hub.  Registers six char
		devices /dev/legoport0../dev/legoport5 that expose:

		 - Device connection manager (DCM, Issue #42): a 2 ms HPWORK
		   state machine ported from pybricks that detects passive
		   resistor-divider devices and latches UART devices at type
		   UNKNOWN_UART (14) for the LUMP engine.
		 - LUMP UART protocol engine (Issue #43, gated by
		   CONFIG_LEGO_LUMP): per-port kernel thread that runs the
		   SYNC / mode-info / DATA loop for active sensors and motors.
		 - H-bridge PWM (Issue #80): direct duty-cycle control over
		   TIM1 / TIM3 / TIM4, used to drive passive Powered Up
		   motors and to hold the supply rail for sensors that
		   announce NEEDS_SUPPLY_PIN1/PIN2 in their LUMP MODE flags.

		Port E (PC6/PC7) shares its physical pins with USART6.  The
		hub also has SWD repurposed for power control (PA13/PA14),
		so disabling USART6 removes the only emergency / early-boot
		debug path — see docs/development/debugging.md.  This
		Kconfig hard-disables itself if STM32_USART6 is enabled —
		pick one or the other.

config LEGO_PORT_DCM_NOOP
	bool "Diagnostic: skip DCM GPIO work (keep HPWORK monitor)"
	default n
	depends on LEGO_PORT
	---help---
		Diagnostic build flag.  When set, legoport_dcm_step() returns
		immediately without performing any GPIO work, but the HPWORK
		invocation timing is still measured by stm32_legoport_get_stats().
		Used to rule the DCM in or out of HPWORK contention bugs.

config LEGO_LUMP
	bool "LEGO LUMP UART protocol engine (Issue #43)"
	default n
	depends on LEGO_PORT
	depends on ARCH_CHIP_STM32F413VG || ARCH_CHIP_STM32F413ZH
	---help---
		Per-port LUMP protocol kthread for the 6 SPIKE Prime Hub I/O
		ports (UART7/4/8/5/10/9 for A..F).  Required by the upcoming
		motor (#44) and sensor (#45) drivers.

		Owns UART4/5/7/8/9/10 directly without going through the
		standard NuttX serial driver — CONFIG_STM32_UARTn is NOT set
		(it would auto-select STM32_UARTn_SERIALDRIVER and register
		/dev/ttyS*).  RCC clocks and pin AF are enabled by the board
		code (`stm32_legoport_uart_hw.c`) on per-port handoff.

config LEGO_LUMP_DIAG
	bool "LUMP diagnostics: lump-hw dump CLI subcommand"
	default n
	depends on LEGO_LUMP
	---help---
		Builds the `port lump-hw dump` debug command that reads
		RCC APB1ENR / APB2ENR, USART BRR / CR1, and NVIC priority and
		enable bits for all six LUMP UARTs.  Useful for bring-up and
		regression diagnosis; leave off for production builds.

config LEGO_SENSOR
	bool "LEGO sensor uORB driver (/dev/uorb/sensor_lego[0..5])"
	default n
	depends on LEGO_LUMP
	depends on SENSORS
	---help---
		Per-port uORB sensor driver (Issue #45) that publishes
		telemetry from any LUMP-capable Powered Up device — Color /
		Ultrasonic / Force sensors and BOOST / Technic / SPIKE motor
		encoders — to /dev/uorb/sensor_lego[0..5] as a fixed 56 byte
		`struct lump_sample_s` envelope.

		Mode switching and writable-mode TX (e.g. Color sensor LED
		control, Ultrasonic LED control) are exposed through custom
		ioctls (`LEGOSENSOR_SELECT` / `LEGOSENSOR_SEND`) gated by
		per-port `LEGOSENSOR_CLAIM` arbitration.

