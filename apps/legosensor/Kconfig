config APP_LEGOSENSOR
	tristate "LEGO sensor uORB CLI utility"
	default n
	depends on LEGO_SENSOR
	---help---
		CLI for inspecting and controlling /dev/uorb/sensor_lego[0..5]
		(Issue #45).  Subcommands: list, info, mode, send, watch,
		claim, release.

		`legosensor watch <N>` is the canonical end-to-end verification
		tool — `dd` and the standard `sensortest` are not compatible
		with the SENSOR_TYPE_CUSTOM uORB topic naming used here.
