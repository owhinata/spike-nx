config APP_LEGOSENSOR
	tristate "LEGO sensor uORB CLI utility"
	default n
	depends on LEGO_SENSOR
	---help---
		CLI for inspecting and controlling the per-class LEGO sensor
		uORB topics under /dev/uorb/sensor_{color,ultrasonic,force,
		motor_m,motor_r,motor_l} (Issue #79).  Subcommands per class:
		info, status, watch, select, send, pwm.

		`legosensor <class> watch` is the canonical end-to-end
		verification tool — `dd` and the standard `sensortest` are
		not compatible with the SENSOR_TYPE_CUSTOM uORB topic naming
		used here.
