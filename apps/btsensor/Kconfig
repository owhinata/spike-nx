config APP_BTSENSOR
	tristate "SPP IMU streaming (btstack, Issue #52)"
	default n
	---help---
		SPIKE Prime Hub Classic Bluetooth SPP (RFCOMM) streaming of
		LSM6DS3TR-C IMU samples.  Requires the CC2564C bring-up in
		boards/spike-prime-hub (Issue #47) and btstack integrated
		under libs/btstack.  Step B skeleton only; activating the
		service happens in Step D.

if APP_BTSENSOR

config APP_BTSENSOR_PROGNAME
	string "Program name"
	default "btsensor"
	depends on BUILD_KERNEL
	---help---
		NSH command name.

config APP_BTSENSOR_PRIORITY
	int "Task priority"
	default 100

config APP_BTSENSOR_STACKSIZE
	int "Task stack size"
	default 4096

config APP_BTSENSOR_BATCH
	int "Default IMU samples per RFCOMM frame"
	default 8
	range 1 80
	---help---
		Number of 12-byte IMU samples packed into one SPP frame.
		8 samples gives ~108 byte payload (~9.6 ms of data at
		833 Hz); the upper bound is set by the negotiated RFCOMM
		MTU (typically 1016 bytes from BlueZ): 12 byte header +
		80 * 12 byte sample = 972 bytes still fits one RFCOMM
		frame.  This is the default; `btsensor [batch]` overrides
		it at runtime.

config APP_BTSENSOR_RING_DEPTH
	int "Frame ring buffer depth"
	default 32
	range 4 128
	---help---
		Number of frames kept between the sampler and the RFCOMM
		send worker.  Deeper rings tolerate longer RF stalls at
		the cost of RAM.

config APP_BTSENSOR_BTN_LONG_PRESS_MS
	int "BT button long-press threshold (ms)"
	default 1500
	range 200 5000
	---help---
		Hold the BT button down at least this long for a
		long-press event; shorter presses register as short.
		Long press toggles BT off when paired or advertising;
		short press starts advertising from BT off.

config APP_BTSENSOR_LED_BLINK_PERIOD_MS
	int "BT LED slow-blink period (ms)"
	default 1000
	range 100 3000
	---help---
		Period of the BT LED blink while advertising
		(half on / half off).

config APP_BTSENSOR_LED_FAIL_BLINKS
	int "BT LED fail-blink pulse count"
	default 3
	range 1 10
	---help---
		Number of short blue blinks emitted when SSP pairing
		fails before the LED returns to off.

endif
