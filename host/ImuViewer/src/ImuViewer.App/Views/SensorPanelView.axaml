<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ImuViewer.App.ViewModels"
             xmlns:ctrl="using:ImuViewer.App.Controls"
             x:Class="ImuViewer.App.Views.SensorPanelView"
             x:DataType="vm:SensorPanelViewModel"
             Padding="6"
             Background="#1F1F22">
  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock Grid.Row="0"
               Text="{Binding Title}"
               FontWeight="SemiBold"
               FontSize="13"
               Foreground="{Binding StatusForeground}" />

    <TextBlock Grid.Row="1"
               Text="{Binding ConnectionStatus}"
               FontSize="11"
               Foreground="#A0A0A0"
               TextWrapping="Wrap" />

    <ctrl:SensorPlotControl Grid.Row="2"
                            Points="{Binding RecentPoints}"
                            MinHeight="60" />

    <TextBlock Grid.Row="3"
               Text="{Binding LatestValuesText}"
               FontFamily="Inter, monospace"
               FontSize="11"
               Foreground="#E0E0E0"
               TextTrimming="CharacterEllipsis" />
  </Grid>
</UserControl>
